#!/usr/bin/env bash
#
#  mlx-shtf
#  mlx-shtf
#
#  Created by Michel Storms on 13/06/2026.
#
#  A fully-offline local AI kit for Apple Silicon — chat, doc Q&A (RAG over
#  local files), and coding help, all running on a local MLX model with zero
#  network. Your break-glass assistant for when cloud models get pulled.

set -euo pipefail

VERSION="0.1.4"
DEFAULT_MODEL="mlx-community/Qwen2.5-14B-Instruct-8bit"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/mlx-shtf"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/mlx-shtf"
LOG_FILE="${SHTF_LOG:-$STATE_DIR/runs.jsonl}"

# Model resolution: $SHTF_MODEL > install-time choice (config) > built-in default.
CFG_MODEL=""
[[ -r "$CONFIG_DIR/model" ]] && CFG_MODEL="$(tr -d '[:space:]' < "$CONFIG_DIR/model")"
MODEL="${SHTF_MODEL:-${CFG_MODEL:-$DEFAULT_MODEL}}"
MAX_TOKENS="${SHTF_MAX_TOKENS:-1024}"
TEMP="${SHTF_TEMP:-0.4}"
MODEL_SHORT="${MODEL##*/}"

die() { printf 'error: %s\n' "$1" >&2; exit 1; }

usage() {
  cat <<EOF
mlx-shtf $VERSION — offline local AI kit for Apple Silicon (chat · ask · code).

Usage:
  mlx-shtf chat                      Interactive offline chat (REPL)
  mlx-shtf ask <path> <question…>    Answer grounded in local files (RAG)
  mlx-shtf code [file] <prompt…>     Coding help; include a file for context
  mlx-shtf <question…>               One-shot question (no files)
  mlx-shtf models                    Show the active model and how to change it
  mlx-shtf --version | -h, --help

Environment:
  SHTF_MODEL        Model repo (default: install-time choice or $DEFAULT_MODEL)
  SHTF_MAX_TOKENS   Max generated tokens (default: 1024)
  SHTF_TEMP         Sampling temperature (default: 0.4)
  SHTF_FORCE=1      Skip the RAM-fit guard
EOF
}

# --- dispatch version/help before any host/model work ---
cmd="${1:-}"
case "$cmd" in
  --version) echo "mlx-shtf $VERSION"; exit 0 ;;
  -h|--help|"") usage; exit 0 ;;
esac
shift

# --- host preflight: MLX is Apple-Silicon-only ---
[[ "$(uname -s)/$(uname -m)" == "Darwin/arm64" ]] || \
  die "mlx-shtf requires Apple Silicon macOS — MLX is not supported on $(uname -s)/$(uname -m)."
command -v mlx_lm.generate >/dev/null 2>&1 || \
  die "mlx_lm not found on PATH. Run ./install.sh (or: pipx install mlx-lm)."

# --- RAM-fit guard: refuse to load a model bigger than free RAM (it swap-kills
#     the Mac otherwise). Only enforceable when the model is already cached. ---
hf_hub_dir() {
  if   [[ -n "${HF_HUB_CACHE:-}" ]]; then printf '%s' "$HF_HUB_CACHE"
  elif [[ -n "${HF_HOME:-}" ]];      then printf '%s/hub' "$HF_HOME"
  else printf '%s/.cache/huggingface/hub' "$HOME"; fi
}
avail_ram_gib() {                    # available RAM in GiB (reclaimable pages)
  local p; p=$(vm_stat 2>/dev/null | awk '/Pages (free|inactive|speculative|purgeable)/ {gsub(/\./,"",$NF); s+=$NF} END{print s+0}')
  echo $(( p * 16384 / 1073741824 ))
}
cached_size_gib() {                  # $1 = repo → cached weight size in GiB, or empty
  local snap; snap="$(hf_hub_dir)/models--${1//\//--}/snapshots"
  [[ -d "$snap" ]] || return 0
  local s ok=0; for s in "$snap"/*/; do [[ -e "$s" ]] && ok=1; done
  (( ok )) || return 0
  echo $(( $(du -sLk "$snap" 2>/dev/null | awk '{print $1}') / 1048576 ))
}
cached_models() {                    # list cached model repo ids (one per line)
  local hub d name; hub="$(hf_hub_dir)"
  [[ -d "$hub" ]] || return 0
  for d in "$hub"/models--*/; do
    [[ -d "${d}snapshots" ]] || continue
    name="$(basename "$d")"; name="${name#models--}"; name="${name//--//}"
    printf '%s\n' "$name"
  done
}

# RAM-fit guard: never swap-kill the Mac. If the chosen model doesn't fit in free
# RAM, fall back to the largest *cached* model that does (works offline). Only if
# nothing cached fits do we refuse. SHTF_FORCE=1 loads the chosen model anyway.
ram_guard() {
  [[ "${SHTF_FORCE:-0}" == "1" ]] && return 0
  local need avail; need="$(cached_size_gib "$MODEL")"
  [[ -n "$need" ]] || return 0                       # not cached → can't size, skip
  avail="$(avail_ram_gib)"
  (( need + 3 <= avail )) && return 0                # fits — go

  local repo gib best="" best_gib=-1
  while IFS= read -r repo; do
    [[ "$repo" == "$MODEL" ]] && continue
    gib="$(cached_size_gib "$repo")"; [[ -n "$gib" ]] || continue
    if (( gib + 3 <= avail && gib > best_gib )); then best="$repo"; best_gib="$gib"; fi
  done < <(cached_models)

  if [[ -n "$best" ]]; then
    echo "warning: $MODEL_SHORT needs ~${need} GB but only ~${avail} GB is free —" >&2
    echo "         falling back to cached ${best##*/} (~${best_gib} GB). SHTF_FORCE=1 to override." >&2
    MODEL="$best"; MODEL_SHORT="${MODEL##*/}"
    return 0
  fi
  die "$MODEL_SHORT needs ~${need} GB and no cached model fits in ~${avail} GB free.
       Close some apps, or set SHTF_FORCE=1 to load it anyway (may swap)."
}

# --- core generation: prompt on stdin, system prompt as $1. Foreground (no
#     backgrounding — that would send stdin to /dev/null) and fed via an
#     explicit redirect so large prompts are passed intact. ---
generate() {
  local sys="$1" inf outf errf rc=0
  inf="$(mktemp)"; outf="$(mktemp)"; errf="$(mktemp)"
  cat > "$inf"
  ram_guard
  printf '→ mlx-shtf: thinking with %s…\n' "$MODEL_SHORT" >&2
  mlx_lm.generate --model "$MODEL" --system-prompt "$sys" --prompt - \
    --max-tokens "$MAX_TOKENS" --temp "$TEMP" --verbose False <"$inf" >"$outf" 2>"$errf" || rc=$?
  if (( rc != 0 )) || ! [[ "$(cat "$outf")" =~ [^[:space:]] ]]; then
    echo "error: generation failed (model: $MODEL_SHORT) — mlx_lm said:" >&2
    sed 's/^/  /' "$errf" >&2
    rm -f "$inf" "$outf" "$errf"
    exit 1
  fi
  cat "$outf"
  rm -f "$inf" "$outf" "$errf"
}

log_run() {                          # $1 = command
  mkdir -p "$(dirname "$LOG_FILE")"
  printf '{"ts":"%s","cmd":"%s","model":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$1" "$MODEL" >> "$LOG_FILE"
}

CHAT_SYS='You are a concise, knowledgeable offline assistant running locally. Answer directly and accurately. If you are unsure, say so rather than inventing details.'
CODE_SYS='You are an expert programmer. Give correct, idiomatic, concise help. Prefer minimal, working code. When given a file, ground your answer in it.'
ASK_SYS='Answer the question using ONLY the provided context from local files. Cite the file path(s) you used. If the answer is not in the context, say "Not found in the provided files." Do not invent details.'

case "$cmd" in
  chat)
    command -v mlx_lm.chat >/dev/null 2>&1 || die "mlx_lm.chat not found (update mlx-lm)."
    ram_guard
    echo "→ mlx-shtf: offline chat with $MODEL_SHORT  (Ctrl-D / 'q' to quit)" >&2
    log_run chat
    exec mlx_lm.chat --model "$MODEL"
    ;;

  code)
    [[ $# -gt 0 ]] || die "usage: mlx-shtf code [file] <prompt…>"
    local_file=""; if [[ -f "$1" ]]; then local_file="$1"; shift; fi
    prompt="$*"
    [[ -n "$prompt" || -n "$local_file" ]] || die "usage: mlx-shtf code [file] <prompt…>"
    log_run code
    if [[ -n "$local_file" ]]; then
      combined="$(printf '%s\n\n=== %s ===\n' "${prompt:-Review this file and explain it.}" "$local_file"; cat "$local_file")"
      generate "$CODE_SYS" <<<"$combined"
    else
      generate "$CODE_SYS" <<<"$prompt"
    fi
    ;;

  ask)
    [[ $# -ge 2 ]] || die "usage: mlx-shtf ask <path> <question…>"
    path="$1"; shift; question="$*"
    [[ -e "$path" ]] || die "path not found: $path"
    log_run ask
    # Lexical retrieval (v0.1; embeddings are a tracked enhancement): rank text
    # files under <path> by how many question keywords they contain, then stuff
    # the top files (up to a char budget) into the context.
    kw="$(printf '%s' "$question" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '\n' | awk 'length>=4' | sort -u)"
    [[ -n "$kw" ]] || die "question has no searchable keywords (use longer words)."
    pat="$(printf '%s' "$kw" | paste -sd'|' -)"
    # Rank text files by keyword hits → temp file. (Flat pipeline, not nested
    # process substitution — bash 3.2 mis-parses `<( … <(…) … )` at runtime.)
    rankf="$(mktemp)"
    find "$path" -type f -size -200k -not -path '*/.git/*' 2>/dev/null | while IFS= read -r f; do
      grep -Iq . "$f" 2>/dev/null || continue            # text files only
      n=$(grep -oiE "$pat" "$f" 2>/dev/null | wc -l | tr -d ' ' || true)
      [[ "${n:-0}" -gt 0 ]] && printf '%s\t%s\n' "$n" "$f"
    done | sort -rn | cut -f2- > "$rankf" || true

    budget=12000; ctx=""; used=0
    while IFS= read -r f; do
      (( used >= budget )) && break
      chunk="$(head -c $(( budget - used )) "$f" 2>/dev/null)"
      ctx="${ctx}"$'\n'"### ${f}"$'\n'"${chunk}"
      used=$(( used + ${#chunk} ))
    done < "$rankf"
    rm -f "$rankf"
    [[ "$ctx" =~ [^[:space:]] ]] || die "no local files under '$path' matched: $question"
    askinput="$(printf 'Context:\n%s\n\nQuestion: %s\n' "$ctx" "$question")"
    generate "$ASK_SYS" <<<"$askinput"
    ;;

  models)
    echo "active model: $MODEL"
    echo "  set per-run:  SHTF_MODEL=<hf-repo> mlx-shtf …"
    echo "  set default:  echo <hf-repo> > $CONFIG_DIR/model   (or re-run ./install.sh)"
    ;;

  *)
    # Unknown first word → treat the whole thing as a one-shot question.
    log_run ask-oneshot
    generate "$CHAT_SYS" <<<"$cmd${*:+ $*}"
    ;;
esac
